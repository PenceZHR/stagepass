# stagepass — optional configuration.
#
# Everything here is OPTIONAL; the defaults work out of the box.
# Copy to `.env`, fill in what you need, then export before starting:
#
#     cp .env.example .env
#     set -a && source .env && set +a && pnpm dev
#
# (Next.js loads .env for the web app; exporting also lets the standalone
#  pipeline worker process see these values.)

# --- AI engines -------------------------------------------------------------

# Path to the OpenAI Codex CLI binary. Only needed if `codex` is NOT on your PATH.
# STAGEPASS_CODEX_BIN=/opt/homebrew/bin/codex

# Anthropic auth for the bundled Claude Code CLI (alternative to `claude` login).
# ANTHROPIC_API_KEY=sk-ant-...

# --- Local runtime ----------------------------------------------------------

# Where the local SQLite business database lives (default: server/db/ship.db).
# STAGEPASS_DB_PATH=server/db/ship.db

# Log directory (default: a repo-local logs directory).
# STAGEPASS_LOG_DIR=./logs
